# ── LLM API Keys (set at least one) ──────────────────────────────────────────
# The app tries Anthropic → Gemini → Groq in order. Set whichever you have.

# Option 1: Anthropic Claude (recommended - most accurate)
# Get free credits at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Option 2: Google Gemini (free tier available)
# Get key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Option 3: Groq (free, fast, Llama3-70b)
# Get key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here
